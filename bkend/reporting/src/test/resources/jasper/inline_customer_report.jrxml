<?xml version="1.0" encoding="UTF-8"?>
<jasperReport name="inline_customer_report"
    pageWidth="595" pageHeight="842" columnWidth="555"
    leftMargin="20" rightMargin="20" topMargin="20" bottomMargin="20">
  <field name="CustomerID" class="java.lang.String"/>
  <field name="CompanyName" class="java.lang.String"/>
  <field name="Country" class="java.lang.String"/>
  <detail>
    <band height="20">
      <element kind="textField" x="0" y="0" width="100" height="20">
        <expression>$F{CustomerID}</expression>
      </element>
      <element kind="textField" x="100" y="0" width="300" height="20">
        <expression>$F{CompanyName}</expression>
      </element>
      <element kind="textField" x="400" y="0" width="155" height="20">
        <expression>$F{Country}</expression>
      </element>
    </band>
  </detail>
</jasperReport>