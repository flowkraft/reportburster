<?xml version="1.0" encoding="UTF-8" ?>
<configuration>

	<!-- Logging Properties -->
	<Properties>
		<Property name="LOG_PATTERN">%d{dd/MM/yyyy HH:mm:ss} %p - %m%n</Property>
		<Property name="LOG_DIR">${sys:PORTABLE_EXECUTABLE_DIR:-.}/logs</Property>
	</Properties>

	<Appenders>

		<Console name="Console" target="SYSTEM_OUT">
            <PatternLayout pattern="${LOG_PATTERN}"/>
        </Console>

		<RollingFile name="info-out"
			fileName="${LOG_DIR}/info.log"
			filePattern="${LOG_DIR}/info-%d{MM-dd-yyyy}.log.zip">

			<PatternLayout pattern="${LOG_PATTERN}" />
			<Policies>
				<SizeBasedTriggeringPolicy size="10MB" />
			</Policies>
			<DefaultRolloverStrategy max="10" />

			<LevelRangeFilter minLevel="INFO" maxLevel="INFO"
				onMatch="ACCEPT" onMismatch="DENY" />

		</RollingFile>

		<RollingFile name="warning-out"
			fileName="${LOG_DIR}/warnings.log"
			filePattern="${LOG_DIR}/warnings-%d{MM-dd-yyyy}.log.zip">

			<PatternLayout pattern="${LOG_PATTERN}" />
			<Policies>
				<SizeBasedTriggeringPolicy size="10MB" />
			</Policies>
			<DefaultRolloverStrategy max="10" />

			<LevelRangeFilter minLevel="WARN" maxLevel="WARN"
				onMatch="ACCEPT" onMismatch="DENY" />

		</RollingFile>

		<RollingFile name="error-out"
			fileName="${LOG_DIR}/errors.log"
			filePattern="${LOG_DIR}/errors-%d{MM-dd-yyyy}.log.zip">

			<PatternLayout pattern="${LOG_PATTERN}" />
			<Policies>
				<SizeBasedTriggeringPolicy size="10MB" />
			</Policies>
			<DefaultRolloverStrategy max="10" />

			<LevelRangeFilter minLevel="ERROR" maxLevel="ERROR"
				onMatch="ACCEPT" onMismatch="DENY" />

		</RollingFile>

		<RollingFile name="debug-out"
			fileName="${LOG_DIR}/debug.log"
			filePattern="${LOG_DIR}/debug-%d{MM-dd-yyyy}.log.zip">

			<PatternLayout pattern="${LOG_PATTERN}" />
			<Policies>
				<SizeBasedTriggeringPolicy size="100MB" />
			</Policies>
			<DefaultRolloverStrategy max="10" />

			<LevelRangeFilter minLevel="DEBUG" maxLevel="DEBUG"
				onMatch="ACCEPT" onMismatch="DENY" />

		</RollingFile>

		<!-- Send all DocumentBurster problems by email -->
		<!-- Correct email account details should be provided -->
		<SMTP name="mailAppender" subject="DocumentBurster Error Log"
			to="adminA@server.com,adminB@server.com" from="appname@server.com"
			smtpHost="email.host" smtpPort="25" smtpUsername="email.user.name"
			smtpPassword="password" bufferSize="50">

			<PatternLayout pattern="${LOG_PATTERN}" />

			<LevelRangeFilter minLevel="ERROR" maxLevel="ERROR"
				onMatch="ACCEPT" onMismatch="DENY" />

		</SMTP>

	</Appenders>
	<Loggers>
		<!-- Log level="debug" will make DocumentBurster more verbose -->
		<Logger name="com.sourcekraft.documentburster" level="info">

			<AppenderRef ref="info-out" />
			<AppenderRef ref="warning-out" />
			<AppenderRef ref="error-out" />
			<AppenderRef ref="debug-out" />

		</Logger>

		<!-- Log com.flowkraft to console + errors only (not info.log to avoid polluting dirty-logs checks) -->
        <Logger name="com.flowkraft" level="info" additivity="false">
            <AppenderRef ref="Console"/>
            <AppenderRef ref="error-out"/>
        </Logger>

		<!-- Root catches Spring-internal loggers (org.springframework.*, reactor.*,
		     io.netty.*, java.*). Without appenders here, exceptions thrown inside
		     Spring's dispatch pipeline (WebFlux error handlers, filter chains) are
		     silently dropped — never reaching errors.log or stdout. -->
		<Root level="warn">
			<AppenderRef ref="Console"/>
			<AppenderRef ref="error-out"/>
		</Root>
	</Loggers>

</configuration>
