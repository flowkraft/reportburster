<?xml version="1.0" encoding="UTF-8"?>
<jasperReport name="employee_detail"
              pageWidth="595" pageHeight="842" columnWidth="515"
              leftMargin="40" rightMargin="40" topMargin="50" bottomMargin="50">

    <parameter name="EmployeeID" class="java.lang.Integer"/>
    <parameter name="FirstName" class="java.lang.String"/>
    <parameter name="LastName" class="java.lang.String"/>
    <parameter name="Title" class="java.lang.String"/>
    <parameter name="City" class="java.lang.String"/>
    <parameter name="Country" class="java.lang.String"/>

    <title height="260">
        <element kind="staticText" x="0" y="0" width="515" height="40" fontSize="18.0" bold="true" hTextAlign="Center" vTextAlign="Middle">
            <text><![CDATA[Employee Detail]]></text>
        </element>
        <element kind="line" x="0" y="45" width="515" height="1"/>
        <element kind="staticText" x="0" y="60" width="150" height="25" fontSize="11.0" bold="true">
            <text><![CDATA[Employee ID:]]></text>
        </element>
        <element kind="textField" x="155" y="60" width="360" height="25" fontSize="11.0">
            <expression><![CDATA[$P{EmployeeID}]]></expression>
        </element>
        <element kind="staticText" x="0" y="90" width="150" height="25" fontSize="11.0" bold="true">
            <text><![CDATA[First Name:]]></text>
        </element>
        <element kind="textField" x="155" y="90" width="360" height="25" fontSize="11.0">
            <expression><![CDATA[$P{FirstName}]]></expression>
        </element>
        <element kind="staticText" x="0" y="120" width="150" height="25" fontSize="11.0" bold="true">
            <text><![CDATA[Last Name:]]></text>
        </element>
        <element kind="textField" x="155" y="120" width="360" height="25" fontSize="11.0">
            <expression><![CDATA[$P{LastName}]]></expression>
        </element>
        <element kind="staticText" x="0" y="150" width="150" height="25" fontSize="11.0" bold="true">
            <text><![CDATA[Title:]]></text>
        </element>
        <element kind="textField" x="155" y="150" width="360" height="25" fontSize="11.0" blankWhenNull="true">
            <expression><![CDATA[$P{Title}]]></expression>
        </element>
        <element kind="staticText" x="0" y="180" width="150" height="25" fontSize="11.0" bold="true">
            <text><![CDATA[City:]]></text>
        </element>
        <element kind="textField" x="155" y="180" width="360" height="25" fontSize="11.0" blankWhenNull="true">
            <expression><![CDATA[$P{City}]]></expression>
        </element>
        <element kind="staticText" x="0" y="210" width="150" height="25" fontSize="11.0" bold="true">
            <text><![CDATA[Country:]]></text>
        </element>
        <element kind="textField" x="155" y="210" width="360" height="25" fontSize="11.0" blankWhenNull="true">
            <expression><![CDATA[$P{Country}]]></expression>
        </element>
    </title>

</jasperReport>
