{
  "name": "flowkraft/datapallas-portal",
  "type": "wordpress-plugin",
  "description": "DataPallas Portal WordPress plugin",
  "version": "1.0.0",
  "keywords": [
    "wordpress"
  ],
  "homepage": "https://datapallas.com/",
  "license": "GPL-3.0",
  "authors": [
    {
      "name": "FlowKraft",
      "email": "support@datapallas.com",
      "homepage": "https://datapallas.com/"
    }
  ],
  "support": {
    "issues": "https://github.com/flowkraft/datapallas/issues",
    "source": "https://github.com/flowkraft/datapallas"
  },
  "require": {
    "php": ">=7.4",
    "wpbones/wpbones": "dev-master",
    "wpbones/wpkirk-helpers": "~2.0"
  },
  "autoload": {
    "psr-4": {
      "DataPallas_Portal\\": "plugin/"
    },
    "files": [
      "functions.php"
    ]
  },
  "config": {
    "process-timeout": 900
  },
  "scripts": {
    "post-autoload-dump": [
      "php -r \"if(!file_exists('bones')) copy('vendor/wpbones/wpbones/src/Console/bin/bones','bones');\"",
      "php -r \"if(!file_exists('.bones_renamed')) { system('php bones rename --update'); file_put_contents('.bones_renamed','1'); }\""
    ]
  }  
}
